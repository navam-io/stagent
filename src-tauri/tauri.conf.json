{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Stagent",
  "version": "0.1.1",
  "identifier": "io.navam.stagent",
  "build": {
    "frontendDist": "shell"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Stagent Desktop",
        "width": 1360,
        "height": 880,
        "minWidth": 1080,
        "minHeight": 680,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../dist",
      "../src",
      "../public",
      "../node_modules",
      "../package.json",
      "../next.config.mjs",
      "../postcss.config.mjs",
      "../tsconfig.json",
      "../components.json",
      "../drizzle.config.ts"
    ]
  }
}
