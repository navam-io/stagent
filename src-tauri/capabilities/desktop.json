{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "desktop-main",
  "description": "Allow the bundled localhost app to access desktop notifications and file dialogs.",
  "windows": ["main"],
  "local": false,
  "remote": {
    "urls": ["http://127.0.0.1:*", "http://localhost:*"]
  },
  "permissions": ["dialog:default", "notification:default"]
}
